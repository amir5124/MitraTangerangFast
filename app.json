{
  "expo": {
    "name": "Mitra Fast",
    "slug": "MitraTangerangFast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/playstore.png",
    "scheme": "mitratangerangfast",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/playstore.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tangerangfast.mitra",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Aplikasi membutuhkan lokasi untuk menentukan titik workshop mitra dan mencocokkan pesanan terdekat.",
        "NSLocationAlwaysUsageDescription": "Aplikasi membutuhkan akses lokasi setiap saat agar pelanggan dapat menemukan jasa Anda dengan akurat."
      }
    },
    "android": {
      "package": "com.tangerangfast.mitra",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAnYqVmhOsyV3SFRFgVFhQrFJdb3_pbrzc"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/playstore.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "notification": {
      "icon": "./assets/notif.png",
      "color": "#633594",
      "iosDisplayInForeground": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAnYqVmhOsyV3SFRFgVFhQrFJdb3_pbrzc"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izinkan MitraTangerangFast mengakses lokasi Anda untuk kebutuhan pemetaan workshop.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7a353a2-5852-4e09-94d7-e837588cb95e"
      }
    }
  }
}